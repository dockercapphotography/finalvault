# =============================================================
# FinalVault — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control
# =============================================================

# Supabase — Production (public schema)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Cloudflare R2 Worker
VITE_R2_WORKER_URL=https://finalvault-worker.your-subdomain.workers.dev

# =============================================================
# Playwright — Test Environment
# PLAYWRIGHT_SUPABASE_URL is the same as VITE_SUPABASE_URL
# PLAYWRIGHT_SUPABASE_SERVICE_KEY is the secret service_role key
# found in Supabase → Settings → API → service_role
# =============================================================

PLAYWRIGHT_BASE_URL=http://localhost:5173
PLAYWRIGHT_SUPABASE_URL=https://xxxx.supabase.co
PLAYWRIGHT_SUPABASE_SERVICE_KEY=your-supabase-service-role-key
PLAYWRIGHT_TEST_SCHEMA=test
PLAYWRIGHT_TEST_EMAIL=playwright@finalvault.test
PLAYWRIGHT_TEST_PASSWORD=your-test-user-password
